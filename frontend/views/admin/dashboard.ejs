<!DOCTYPE html>
<html lang="en">
<%- include('../../components/header') %>
<body>
    <%- include('../../components/navbar') %>
    
    <div class="container dashboard-container">
        <h2>Admin Dashboard</h2>
        
        <div class="stats-grid">
            <div class="stat-card">
                <h3><%= stats.totalVisits || 0 %></h3>
                <p>Total Visits</p>
            </div>
            <div class="stat-card">
                <h3><%= stats.pendingVisits || 0 %></h3>
                <p>Pending Visits</p>
            </div>
            <div class="stat-card">
                <h3><%= stats.totalStudents || 0 %></h3>
                <p>Total Students</p>
            </div>
            <div class="stat-card">
                <h3><%= stats.totalUsers || 0 %></h3>
                <p>Total Users</p>
            </div>
        </div>
        
        <div class="dashboard-section">
            <h3>Quick Actions</h3>
            <ul>
                <li><a href="/visits/all">Manage Visits</a></li>
                <li><a href="/students">Manage Students</a></li>
                <li><a href="/users">Manage Users</a></li>
            </ul>
        </div>
        
        <div class="dashboard-section">
            <h3>Pending Visit Requests</h3>
            <% if (visits && visits.filter(v => v.status === 'Pending').length > 0) { %>
                <table class="visits-table">
                    <thead>
                        <tr>
                            <th>Parent</th>
                            <th>Student</th>
                            <th>Date</th>
                            <th>Time</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% visits.filter(v => v.status === 'Pending').forEach(visit => { %>
                            <tr>
                                <td><%= visit.parent %></td>
                                <td><%= visit.student %></td>
                                <td><%= visit.date %></td>
                                <td><%= visit.time %></td>
                                <td><span class="status <%= visit.status.toLowerCase() %>"><%= visit.status %></span></td>
                                <td>
                                    <button class="btn btn-success" onclick="updateVisitStatus(<%= visit.id %>, 'Approved')">Approve</button>
                                    <button class="btn btn-danger" onclick="updateVisitStatus(<%= visit.id %>, 'Rejected')">Reject</button>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            <% } else { %>
                <p>No pending visit requests.</p>
            <% } %>
        </div>
    </div>
    
    <%- include('../../components/footer') %>
    <script src="/js/main.js"></script>
</body>
</html>
