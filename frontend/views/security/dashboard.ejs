<!DOCTYPE html>
<html lang="en">
<%- include('../../components/header') %>
<body>
    <%- include('../../components/navbar') %>
    
    <div class="container dashboard-container">
        <h2>Security Officer Dashboard</h2>
        
        <div class="stats-grid">
            <div class="stat-card">
                <h3><%= visitsCount || 0 %></h3>
                <p>Total Visits</p>
            </div>
        </div>
        
        <div class="dashboard-section">
            <h3>Quick Actions</h3>
            <ul>
                <li><a href="/visits/all">View All Visits</a></li>
                <li><a href="/security/visit-schedule">Visit Schedule</a></li>
            </ul>
        </div>
        
        <div class="dashboard-section">
            <h3>Visit Log</h3>
            <% if (visits && visits.length > 0) { %>
                <table class="visits-table">
                    <thead>
                        <tr>
                            <th>Parent</th>
                            <th>Student</th>
                            <th>Date</th>
                            <th>Time</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% visits.forEach(visit => { %>
                            <tr>
                                <td><%= visit.parent %></td>
                                <td><%= visit.student %></td>
                                <td><%= visit.date %></td>
                                <td><%= visit.time %></td>
                                <td><span class="status <%= visit.status.toLowerCase() %>"><%= visit.status %></span></td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            <% } else { %>
                <p>No visits scheduled.</p>
            <% } %>
        </div>
    </div>
    
    <%- include('../../components/footer') %>
    <script src="/js/main.js"></script>
</body>
</html>
