<!DOCTYPE html>
<html lang="en">
<%- include('../../components/header') %>
<body>
    <%- include('../../components/navbar') %>
    
    <div class="container">
        <h2>My Visit Status</h2>
        
        <% if (visits && visits.length > 0) { %>
            <table class="visits-table">
                <thead>
                    <tr>
                        <th>Student</th>
                        <th>Date</th>
                        <th>Time</th>
                        <th>Status</th>
                        <th>Reason</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% visits.forEach(visit => { %>
                        <tr>
                            <td><%= visit.student %></td>
                            <td><%= visit.date %></td>
                            <td><%= visit.time %></td>
                            <td><span class="status <%= visit.status.toLowerCase() %>"><%= visit.status %></span></td>
                            <td><%= visit.reason %></td>
                            <td>
                                <% if (visit.status === 'Pending') { %>
                                    <a href="#" class="btn-small">Edit</a>
                                    <a href="#" class="btn-small btn-danger">Cancel</a>
                                <% } %>
                            </td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        <% } else { %>
            <p>You have no visits scheduled.</p>
        <% } %>
        
        <a href="/visits/request" class="btn btn-primary">Request New Visit</a>
    </div>
    
    <%- include('../../components/footer') %>
    <script src="/js/main.js"></script>
</body>
</html>
