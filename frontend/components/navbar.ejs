<!-- frontend/components/navbar.ejs -->
<nav class="navbar">
    <div class="navbar-brand">
        <h1>Boarding School Visiting System</h1>
    </div>
    <div class="navbar-links">
        <a href="/" class="nav-link">Home</a>
        <a href="/dashboard" class="nav-link">Dashboard</a>
        <a href="/visits/request" class="nav-link">Request Visit</a>
        <a href="/notifications" class="nav-link">Notifications</a>
    </div>
    <div class="navbar-menu">
        <% if (session && session.userId) { %>
            <span class="user-info">Welcome, <strong><%= session.userName || 'User' %></strong> (<%= session.userRole %>)</span>
            <a href="/auth/logout" class="btn-logout">Logout</a>
        <% } else { %>
            <a href="/auth/login" class="btn-login">Login</a>
            <a href="/auth/register" class="btn-register">Register</a>
        <% } %>
    </div>
</nav>
